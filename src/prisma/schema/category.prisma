model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  icon        String?
  iconPublicId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  questions   Question[]

  @@index([name])
  @@index([slug])
  @@map("categories")
}
