model Question {
  id         String    @id @default(cuid())
  text       String
  options    String[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@index([createdAt])
}
