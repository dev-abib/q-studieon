model Report {
  id                      String             @id @default(cuid())
  userId                  String?
  type                    String
  status                  ReportStatus       @default(pending)
  metadata                Json?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  aiModel                 String?
  auspiciousnessLevel     String?
  auspiciousnessSummary   String?
  completionTokens        Int?
  entranceDirection       Json?
  entranceEnergy          Json?
  familyFlowNarrative     String?
  familyFlowSummary       String?
  fengShui                Json?
  finishReason            String?
  helpfulTips             Json?
  indicators              Json?
  lifeAspects             Json?
  numerology              Json?
  overallAlignmentSummary String?
  overallScore            Int?
  overview                String?
  photos                  Json?
  placeId                 String?
  practicalRemedies       Json?
  promptTokens            Int?
  totalTokens             Int?
  vastu                   Json?
  ReportCollection        ReportCollection[]
  user                    User?              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([type])
  @@index([status])
  @@index([placeId])
  @@map("reports")
}

enum ReportStatus {
  pending
  completed
  failed
}
